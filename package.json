{
  "name": "empower-mind",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "check": "astro check",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "build": "astro check && astro build",
    "preview": "pnpm run build && wrangler dev",
    "deploy": "pnpm run build && wrangler deploy",
    "deploy:preview": "pnpm build && wrangler pages deploy dist --project-name=empower-mind --branch=preview",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/sitemap": "latest",
    "astro": "latest"
  },
  "devDependencies": {
    "@astrojs/check": "latest",
    "prettier": "latest",
    "prettier-plugin-astro": "latest",
    "typescript": "^5.9.3",
    "vitest": "latest",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": ">=22"
  }
}

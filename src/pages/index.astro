---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/data/site';
---

<BaseLayout
  description="Empower Mind promotes youth mental health, psychosocial well-being, and social resilience from a Zomba District pilot towards national reach in Malawi."
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy" data-reveal="immediate">
        <p class="eyebrow">Youth mental health · Zomba District, Malawi</p>
        <h1>Minds grow stronger when systems listen.</h1>
        <p class="lede">
          Empower Mind brings young people, communities, schools, universities, and public systems
          into one connected response for psychosocial well-being.
        </p>
        <div class="hero-actions">
          <a class="button-link" href="/programs">Explore programmes</a><a
            class="button-link button-link--quiet"
            href={`mailto:${site.contact.email}`}>Start a partnership</a
          >
        </div>
      </div>
      <div class="hero-field" data-reveal="immediate">
        <span class="hero-ring" data-parallax="0.045" aria-hidden="true"></span><span
          class="hero-sun"
          data-parallax="-0.035"
          aria-hidden="true"></span><span class="hero-band" aria-hidden="true"
          >Pilot here. Learning outward.</span
        >
        <aside class="hero-support" aria-labelledby="support-title">
          <p class="eyebrow">Support the work</p>
          <h2 id="support-title">Want to contribute?</h2>
          <p>
            A public online donation route is not yet available. Contact Empower Mind directly for
            donation and funding enquiries.
          </p>
          <a href={`mailto:${site.contact.email}?subject=Donation enquiry`}
            >Donation enquiries <span aria-hidden="true">↗</span></a
          >
        </aside>
      </div>
    </div>
  </section>

  <div class="signal-band" aria-hidden="true">
    <div>
      LISTEN DEEPLY · BUILD LOCALLY · LEARN OPENLY · LISTEN DEEPLY · BUILD LOCALLY · LEARN OPENLY ·
    </div>
  </div>

  <section class="context">
    <div class="container context-grid" data-reveal>
      <p class="eyebrow">The pressure is connected</p>
      <h2 data-reveal="wipe">
        Well-being is shaped in classrooms, homes, communities, and public life.
      </h2>
      <div class="context-copy">
        <p>
          Education and employment pressures, climate shocks, social inequality, trauma, substance
          use, depression, anxiety, and suicide risk can intersect in young people’s lives.
        </p><p>
          Empower Mind’s response moves from awareness and early identification towards peer
          support, referral, advocacy, research, and stronger institutions.
        </p>
      </div>
    </div>
  </section>

  <section class="response" id="approach">
    <div class="container">
      <header class="response-head" data-reveal>
        <p class="eyebrow">A connected response</p><h2>
          Support is not one programme or one doorway.
        </h2><p>
          Five working groups make the model legible without separating work that depends on
          connection.
        </p>
      </header>
      <ol class="response-path">
        {
          site.responseModel.map((item, index) => (
            <li data-reveal class={`tone-${index + 1}`} style={`--reveal-delay: ${index * 70}ms`}>
              <>
                <span>{item.number}</span>
                <div>
                  <>
                    <h3>{item.title}</h3>
                    <p>{item.summary}</p>
                  </>
                </div>
              </>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="chapters">
    <div class="container chapters-grid">
      <div class="chapters-intro" data-reveal>
        <p class="eyebrow">Empower Mind Chapters</p><h2>Local platforms. Institutional reach.</h2><p
          class="lede"
        >
          Empower Mind has established its chapter model across five named higher-education
          institutions. Peer support, referral pathways, training, and mentorship form part of the
          wider way of working.
        </p><a class="button-link" href="/programs">Understand the chapter model</a>
      </div>
      <ol class="campus-list" aria-label="Institutions with Empower Mind Chapters">
        {
          site.chapters.map((chapter, index) => (
            <li data-reveal style={`--reveal-delay: ${index * 55}ms`}>
              <>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <strong>{chapter}</strong>
              </>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="programmes">
    <div class="container">
      <header class="programme-head" data-reveal>
        <p class="eyebrow">Three programme areas</p><h2>Different settings. One shared purpose.</h2>
      </header>
      <div class="programme-field">
        {
          site.programs.map((program, index) => (
            <article
              class={`programme programme-${index + 1}`}
              data-reveal
              style={`--reveal-delay: ${index * 90}ms`}
            >
              <>
                <p class="programme-number">Programme {program.number}</p>
                <h3>{program.title}</h3>
                <p>{program.summary}</p>
                <a href={program.href}>
                  Explore programme information <span aria-hidden="true">↗</span>
                </a>
              </>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="accountability">
    <div class="container accountability-grid" data-reveal>
      <div>
        <p class="eyebrow">Learning & accountability</p><h2>Good intentions need a record.</h2><p
          class="lede"
        >
          Results-based monitoring and evaluation, quarterly implementation reporting to the
          Ministry of Health, and continuous learning are part of the stated approach.
        </p>
      </div>
      <div class="accountability-track">
        <div><strong>Document</strong><span>Attendance registers · Activity reports</span></div><div
        >
          <strong>Follow</strong><span>Referral logs · Feedback tools</span>
        </div><div>
          <strong>Protect</strong><span>Confidentiality · Safeguarding · Informed consent</span>
        </div><div><strong>Learn</strong><span>Review, adapt, and strengthen delivery</span></div>
      </div>
    </div>
  </section>

  <section class="partnership">
    <div class="container partnership-grid" data-reveal>
      <div>
        <p class="eyebrow">Build the response together</p><h2>
          Bring your institution into the conversation.
        </h2>
      </div><div>
        <p>
          Cross-sector partnerships are part of Empower Mind’s stated approach to sustainability and
          gradual geographic expansion.
        </p><a class="button-link" href={`mailto:${site.contact.email}`}>Email Empower Mind</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--paper);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    min-height: 100svh;
    align-items: stretch;
  }
  .hero-copy {
    z-index: 1;
    align-self: center;
    max-width: 54rem;
    padding-block: clamp(7rem, 12vh, 8.5rem) clamp(2.5rem, 7vh, 4.5rem);
  }
  .hero h1 {
    max-width: 12ch;
    margin-bottom: var(--space-4);
    font-size: clamp(3.4rem, 6.4vw, 6.4rem);
    line-height: 0.9;
  }
  .hero .lede {
    max-width: 39rem;
    font-size: clamp(1.05rem, 1.5vw, 1.35rem);
    line-height: 1.4;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
  .hero-field {
    position: relative;
    min-height: 34rem;
  }
  .hero-ring {
    position: absolute;
    width: min(34vw, 29rem);
    aspect-ratio: 1;
    top: 10%;
    right: -5%;
    border: clamp(3rem, 7vw, 7rem) solid var(--navy-950);
    border-radius: 50%;
  }
  .hero-sun {
    position: absolute;
    width: clamp(7rem, 15vw, 13rem);
    aspect-ratio: 1;
    right: 38%;
    bottom: 9%;
    border-radius: 50% 50% 12% 50%;
    background: var(--coral);
    transform: rotate(18deg);
  }
  .hero-band {
    position: absolute;
    right: 0;
    bottom: 14%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--navy-950);
    background: var(--amber-soft);
    color: var(--navy-950);
    font-size: var(--step--1);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transform: rotate(-4deg);
  }
  .hero-support {
    position: absolute;
    z-index: 2;
    right: 0;
    bottom: clamp(2rem, 6vh, 5rem);
    width: min(100%, 20rem);
    padding: var(--space-4);
    border: 1px solid var(--navy-950);
    border-radius: var(--radius-medium);
    background: rgba(248, 244, 236, 0.94);
    box-shadow: 0.65rem 0.65rem 0 var(--coral);
    backdrop-filter: blur(12px);
  }
  .hero-support .eyebrow {
    margin-bottom: var(--space-2);
  }
  .hero-support h2 {
    margin-bottom: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--step-2);
  }
  .hero-support p:not(.eyebrow) {
    margin-bottom: var(--space-3);
    font-size: var(--step--1);
    line-height: 1.5;
  }
  .hero-support a {
    font-size: var(--step--1);
    font-weight: 850;
  }
  .signal-band {
    overflow: hidden;
    border-block: 1px solid var(--navy-950);
    background: var(--amber-soft);
  }
  .signal-band div {
    width: max-content;
    padding-block: 0.72rem;
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.18em;
    animation: signal-roll 24s linear infinite;
  }
  @keyframes signal-roll {
    to {
      transform: translateX(-50%);
    }
  }
  .context {
    padding-block: var(--space-8);
    background: var(--navy-950);
    color: var(--cream);
  }
  .context-grid {
    display: grid;
    grid-template-columns: 0.45fr 1.2fr 0.7fr;
    gap: var(--space-6);
    align-items: start;
  }
  .context h2 {
    max-width: 14ch;
  }
  .context-copy {
    padding-top: 0.5rem;
    border-top: 4px solid var(--sky);
    color: rgba(255, 248, 233, 0.78);
  }
  .response {
    padding-block: var(--space-8);
    background: var(--cream);
  }
  .response-head {
    display: grid;
    grid-template-columns: 0.45fr 1.15fr 0.7fr;
    gap: var(--space-6);
    align-items: end;
    margin-bottom: var(--space-7);
  }
  .response-head h2 {
    max-width: 13ch;
    margin: 0;
  }
  .response-path {
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    gap: var(--space-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .response-path li {
    grid-column: span 4;
    min-height: 15rem;
    padding: var(--space-5);
    border: 1px solid var(--line);
    border-radius: var(--radius-large) var(--radius-small) var(--radius-large) var(--radius-small);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .response-path li:nth-child(2),
  .response-path li:nth-child(5) {
    grid-column: span 6;
  }
  .response-path li > span {
    font-family: var(--font-display);
    font-size: var(--step-2);
  }
  .response-path h3 {
    max-width: 15ch;
    margin-bottom: var(--space-3);
  }
  .response-path p {
    max-width: 38rem;
    margin: 0;
  }
  .tone-1,
  .tone-3,
  .tone-5 {
    background: var(--paper);
  }
  .tone-2 {
    background: var(--sky);
  }
  .tone-4 {
    background: var(--pink);
  }
  .chapters {
    padding-block: var(--space-8);
    background: var(--navy-950);
    color: var(--cream);
  }
  .chapters-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: var(--space-7);
    align-items: start;
  }
  .chapters-intro {
    position: sticky;
    top: var(--space-4);
  }
  .chapters-intro h2 {
    max-width: 10ch;
  }
  .campus-list {
    margin: 0;
    padding: 0;
    border-top: 1px solid rgba(248, 244, 236, 0.4);
    list-style: none;
  }
  .campus-list li {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: var(--space-3);
    align-items: center;
    padding: var(--space-5) var(--space-3);
    border-bottom: 1px solid rgba(248, 244, 236, 0.4);
  }
  .campus-list span {
    font-size: var(--step--1);
    font-weight: 800;
  }
  .campus-list strong {
    font-size: var(--step-1);
    line-height: 1.25;
  }
  .programmes {
    padding-block: var(--space-8);
    background: var(--paper);
  }
  .programme-head {
    display: grid;
    grid-template-columns: 0.5fr 1.5fr;
    gap: var(--space-6);
    margin-bottom: var(--space-7);
  }
  .programme-head h2 {
    max-width: 15ch;
  }
  .programme-field {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: var(--space-4);
    align-items: stretch;
  }
  .programme {
    padding: var(--space-6);
    border: 1px solid var(--navy-950);
  }
  .programme-1 {
    grid-row: span 2;
    min-height: 32rem;
    border-radius: 0 var(--radius-large) 0 var(--radius-large);
    background: var(--amber-soft);
  }
  .programme-2 {
    background: var(--navy-950);
    color: var(--cream);
  }
  .programme-3 {
    border-radius: var(--radius-large) 0 0 0;
    background: var(--sky);
  }
  .programme-number {
    font-size: var(--step--1);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .programme h3 {
    max-width: 18ch;
  }
  .programme p:not(.programme-number) {
    max-width: 34rem;
  }
  .programme a {
    font-weight: 800;
  }
  .accountability {
    padding-block: var(--space-8);
    background: var(--cream);
  }
  .accountability-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--space-7);
  }
  .accountability h2 {
    max-width: 11ch;
  }
  .accountability-track {
    border-left: 4px solid var(--navy-950);
  }
  .accountability-track div {
    position: relative;
    display: grid;
    grid-template-columns: 0.35fr 1fr;
    gap: var(--space-3);
    padding: var(--space-4) 0 var(--space-4) var(--space-5);
    border-bottom: 2px solid var(--navy-950);
  }
  .accountability-track div::before {
    position: absolute;
    left: -0.65rem;
    top: 2rem;
    width: 1rem;
    aspect-ratio: 1;
    border: 2px solid var(--navy-950);
    border-radius: 50%;
    background: var(--paper);
    content: '';
  }
  .partnership {
    padding-block: var(--space-8);
    border-top: 1px solid var(--line);
    background: var(--paper);
  }
  .partnership-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-7);
    align-items: end;
  }
  .partnership h2 {
    max-width: 13ch;
    margin: 0;
  }
  @media (max-width: 62rem) {
    .context-grid,
    .response-head {
      grid-template-columns: 1fr 1.4fr;
    }
    .context-copy,
    .response-head > p:last-child {
      grid-column: 2;
    }
    .chapters-grid,
    .accountability-grid {
      gap: var(--space-6);
    }
    .chapters-intro {
      position: static;
    }
  }
  @media (max-width: 48rem) {
    .hero-grid,
    .context-grid,
    .response-head,
    .chapters-grid,
    .programme-head,
    .programme-field,
    .accountability-grid,
    .partnership-grid {
      grid-template-columns: 1fr;
    }
    .hero-grid {
      min-height: auto;
    }
    .hero-copy {
      padding-block: 6.75rem var(--space-4);
    }
    .hero h1 {
      max-width: 11ch;
      font-size: clamp(3rem, 15vw, 4.6rem);
    }
    .hero .lede {
      font-size: 1.05rem;
    }
    .hero-actions {
      gap: var(--space-2);
      margin-top: var(--space-3);
    }
    .hero-field {
      min-height: 19rem;
    }
    .hero-ring {
      width: 14rem;
      border-width: 3.5rem;
    }
    .hero-sun {
      right: auto;
      left: 10%;
    }
    .hero-support {
      right: auto;
      bottom: var(--space-4);
      left: 0;
      width: 100%;
    }
    .context-copy,
    .response-head > p:last-child {
      grid-column: auto;
    }
    .response-path {
      grid-template-columns: 1fr;
    }
    .response-path li,
    .response-path li:nth-child(2),
    .response-path li:nth-child(5) {
      grid-column: auto;
      min-height: 13rem;
    }
    .programme-1 {
      min-height: 22rem;
    }
  }
  @media (min-width: 48.01rem) and (max-height: 46rem) {
    .hero-copy {
      padding-block: 6.5rem 2rem;
    }
    .hero h1 {
      max-width: 13ch;
      font-size: clamp(3.2rem, 6vw, 5rem);
    }
    .hero .lede {
      font-size: 1.05rem;
    }
    .hero-actions {
      margin-top: var(--space-3);
    }
  }
  @media (max-width: 24rem) {
    .campus-list li {
      grid-template-columns: 2.5rem 1fr;
      padding-inline: 0;
    }
    .accountability-track div {
      grid-template-columns: 1fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .signal-band div {
      animation: none;
    }
  }
</style>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/data/site';
---

<BaseLayout
  title="Let’s talk"
  description="Contact Empower Mind Initiative by email or phone about programmes, research, advocacy, and cross-sector partnership."
>
  <section class="contact-hero">
    <div class="container contact-grid">
      <div data-reveal="immediate">
        <p class="eyebrow">Let’s talk</p><h1>Start with a direct conversation.</h1><p class="lede">
          For programme questions, institutional collaboration, research, advocacy, or general
          enquiries, use one of Empower Mind’s confirmed contact routes.
        </p>
      </div><div class="contact-mark" aria-hidden="true" data-reveal="immediate">
        <i data-parallax=".04"></i><span>↗</span>
      </div>
    </div>
  </section>

  <section class="contact-routes">
    <div class="container route-grid">
      <a class="email-route" href={`mailto:${site.contact.email}`} data-reveal
        ><span class="route-label">Email</span><strong>{site.contact.email}</strong><span
          aria-hidden="true">↗</span
        ></a
      ><div class="phone-routes">
        {
          site.contact.phones.map((phone, index) => (
            <a
              href={`tel:${phone.replace(/\s/g, '')}`}
              data-reveal
              style={`--reveal-delay: ${index * 80}ms`}
            >
              <>
                <span class="route-label">Phone {index + 1}</span>
                <strong>{phone}</strong>
                <span aria-hidden="true">↗</span>
              </>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="contact-context">
    <div class="container context-grid">
      <div data-reveal>
        <p class="eyebrow">Working context</p><h2>
          Zomba District. Southern Region. National ambition.
        </h2>
      </div><div data-reveal>
        <p>
          Empower Mind’s profile identifies Zomba District as its pilot context and gradual
          geographic expansion as part of its sustainability approach.
        </p><p>
          The organization has not published an office address or standard response time, so neither
          is implied here.
        </p>
      </div>
    </div>
  </section>

  <aside class="safety-note">
    <div class="container safety-grid">
      <strong>Important</strong><p>
        This website and these organizational contacts are informational. They are not presented as
        an emergency or crisis service. Locally verified crisis pathways have not yet been supplied
        for publication.
      </p>
    </div>
  </aside>
</BaseLayout>

<style>
  .contact-hero {
    min-height: 46rem;
    display: grid;
    align-items: center;
    padding: 9rem 0 var(--space-7);
    background: var(--paper);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-6);
    align-items: center;
  }
  h1 {
    max-width: 10ch;
  }
  .contact-mark {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 24rem;
  }
  .contact-mark i {
    position: absolute;
    width: min(28vw, 21rem);
    aspect-ratio: 1;
    border: clamp(3rem, 6vw, 5rem) solid var(--coral);
    border-right-color: var(--amber-soft);
    border-radius: 50%;
    transform: rotate(-25deg);
  }
  .contact-mark span {
    z-index: 1;
    font-family: var(--font-display);
    font-size: var(--step-5);
  }
  .contact-routes {
    padding-block: var(--space-8);
    background: var(--navy-950);
    color: var(--cream);
  }
  .route-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: var(--space-4);
  }
  .email-route,
  .phone-routes a {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-4);
    padding: var(--space-5);
    border: 1px solid rgba(248, 244, 236, 0.35);
    text-decoration: none;
    transition:
      background var(--motion-fast),
      color var(--motion-fast),
      transform var(--motion-fast);
  }
  .email-route {
    min-height: 20rem;
    align-content: space-between;
    border-radius: 0 var(--radius-large) 0 var(--radius-large);
  }
  .phone-routes {
    display: grid;
    gap: var(--space-4);
  }
  .phone-routes a {
    min-height: 9.5rem;
  }
  .email-route:hover,
  .phone-routes a:hover {
    background: var(--amber-soft);
    color: var(--navy-950);
    transform: translateY(-3px);
  }
  .route-label {
    grid-column: 1 / -1;
    font-size: var(--step--1);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .email-route strong,
  .phone-routes strong {
    overflow-wrap: anywhere;
    font-size: var(--step-1);
  }
  .contact-context {
    padding-block: var(--space-8);
    background: var(--sky);
  }
  .context-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-7);
  }
  .context-grid h2 {
    max-width: 12ch;
  }
  .safety-note {
    padding-block: var(--space-5);
    background: var(--amber-soft);
  }
  .safety-grid {
    display: grid;
    grid-template-columns: 0.3fr 1fr;
    gap: var(--space-5);
  }
  .safety-grid p {
    max-width: 55rem;
    margin: 0;
  }
  @media (max-width: 48rem) {
    .contact-hero {
      min-height: 42rem;
    }
    .contact-grid,
    .route-grid,
    .context-grid,
    .safety-grid {
      grid-template-columns: 1fr;
    }
    .contact-mark {
      min-height: 12rem;
      opacity: 0.35;
    }
    .contact-mark i {
      width: 11rem;
      border-width: 2.5rem;
    }
    .email-route {
      min-height: 14rem;
    }
  }
</style>

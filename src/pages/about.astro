---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/data/site';
import profile from '../../project-content/empower-mind-profile.json';

const timeline = profile.implementationTimeline;
---

<BaseLayout
  title="About"
  description="About Empower Mind Initiative, a youth-focused mental-health and psychosocial well-being organization piloting its work in Zomba District, Malawi."
>
  <section class="about-hero">
    <div class="container about-lead" data-reveal="immediate">
      <p class="eyebrow">About Empower Mind Initiative</p>
      <h1>Well-being grows through people, places, and systems.</h1>
      <div class="lead-detail">
        <p class="lede">
          Empower Mind promotes youth mental health and psychosocial well-being, beginning with a
          pilot in Zomba District and working towards national reach.
        </p>
      </div>
    </div>
    <div class="about-orbit">
      <i class="orbit-motion" data-parallax="0.04" aria-hidden="true"></i><i
        data-parallax="-0.03"
        aria-hidden="true"></i>
      <p class="about-context">Southern Region, Malawi<br />National ambition</p>
    </div>
  </section>

  <section class="purpose">
    <div class="container purpose-grid">
      <p class="eyebrow" data-reveal>Purpose</p>
      <blockquote data-reveal="wipe">
        “To improve the mental health and psychosocial well-being of adolescents, youth, and
        vulnerable communities.”
      </blockquote>
      <p data-reveal>
        Empower Mind’s mission connects accessible services, community empowerment, research, and
        advocacy across Malawi and beyond.
      </p>
    </div>
  </section>

  <section class="work" data-objective-story>
    <div class="container work-grid">
      <header data-reveal>
        <span class="work-ghost" data-objective-ghost aria-hidden="true">01</span>
        <p class="eyebrow">What the organization is working towards</p><h2>
          Seven practical objectives. One connected direction.
        </h2>
        <p class="work-progress" aria-hidden="true">
          Objective <strong data-objective-counter>01</strong> of 07
        </p>
      </header>
      <ol class="objective-list">
        <li data-reveal data-objective-index="1">
          <span>01</span><p>
            Accessible, affordable, quality counselling, therapy, and psychosocial support.
          </p>
        </li>
        <li data-reveal data-objective-index="2">
          <span>02</span><p>
            Mental-health awareness and education in communities and institutions.
          </p>
        </li>
        <li data-reveal data-objective-index="3">
          <span>03</span><p>
            Suicide and self-harm prevention through early identification, referral, and peer
            support.
          </p>
        </li>
        <li data-reveal data-objective-index="4">
          <span>04</span><p>Advocacy and policy dialogue.</p>
        </li>
        <li data-reveal data-objective-index="5">
          <span>05</span><p>Training that strengthens community-based support systems.</p>
        </li>
        <li data-reveal data-objective-index="6">
          <span>06</span><p>
            Support for children and young people facing mental-health and socioeconomic pressures
            to remain in education.
          </p>
        </li>
        <li data-reveal data-objective-index="7">
          <span>07</span><p>Research for evidence-based intervention and policy engagement.</p>
        </li>
      </ol>
    </div>
  </section>

  <section class="timeline" aria-labelledby="timeline-heading">
    <div class="container timeline-intro" data-reveal>
      <div>
        <p class="eyebrow">Where we are going</p>
        <h2 id="timeline-heading">The 2026 implementation plan.</h2>
      </div>
      <div>
        <p class="lede">
          A January–December sequence connecting chapter strengthening, schools, university suicide
          prevention, organizational launch, and stakeholder collaboration.
        </p>
        <p class="plan-note">Plan status: these are scheduled activities.</p>
      </div>
    </div>
    <div class="container timeline-shell">
      <div class="timeline-line" aria-hidden="true"></div>
      <ol class="timeline-list">
        {
          timeline.phases.map((phase, index) => (
            <li data-reveal style={`--reveal-delay: ${index * 65}ms`}>
              <div class="phase-marker" aria-hidden="true">
                <span>{String(index + 1).padStart(2, '0')}</span>
              </div>
              <article>
                <p class="phase-period">{phase.period}</p>
                <h3>{phase.title}</h3>
                <ul>
                  {phase.activities.map((activity) => (
                    <li>{activity}</li>
                  ))}
                </ul>
              </article>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="principles">
    <div class="container principles-grid">
      <div data-reveal>
        <p class="eyebrow">How the work is sustained</p><h2>
          Build capacity. Keep learning. Expand carefully.
        </h2>
      </div><ul data-reveal>
        <li>Capacity building</li><li>Institutionalized chapters</li><li>
          Cross-sector partnerships
        </li><li>Documentation, learning, and research</li><li>Gradual geographic expansion</li>
      </ul>
    </div>
  </section>

  <section class="about-next">
    <div class="container next-grid" data-reveal>
      <h2>See the work taking shape.</h2><div>
        <p>
          The current programme areas connect higher education, prevention, schools, and community
          systems.
        </p><a class="button-link" href="/programs">Explore programmes</a><a
          class="text-link"
          href={`mailto:${site.contact.email}`}>Start a conversation</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const objectiveStory = document.querySelector<HTMLElement>('[data-objective-story]');
  const objectiveRows = objectiveStory?.querySelectorAll<HTMLElement>('[data-objective-index]');
  const objectiveCounter = objectiveStory?.querySelector<HTMLElement>('[data-objective-counter]');
  const objectiveGhost = objectiveStory?.querySelector<HTMLElement>('[data-objective-ghost]');
  const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (
    objectiveRows?.length &&
    objectiveCounter &&
    objectiveGhost &&
    'IntersectionObserver' in window
  ) {
    objectiveStory?.setAttribute('data-enhanced', '');
    let currentObjective = 1;
    let animationFrame = 0;
    const renderObjective = (value: number) => {
      const text = String(value).padStart(2, '0');
      objectiveCounter.textContent = text;
      objectiveGhost.textContent = text;
    };
    const animateObjective = (next: number) => {
      cancelAnimationFrame(animationFrame);
      if (reducedMotion || next === currentObjective) {
        currentObjective = next;
        renderObjective(next);
        return;
      }
      const start = currentObjective;
      const startedAt = performance.now();
      const tick = (now: number) => {
        const progress = Math.min(1, (now - startedAt) / 340);
        renderObjective(Math.round(start + (next - start) * progress));
        if (progress < 1) animationFrame = requestAnimationFrame(tick);
        else currentObjective = next;
      };
      animationFrame = requestAnimationFrame(tick);
    };
    const objectiveObserver = new IntersectionObserver(
      (entries) => {
        const active = entries
          .filter((entry) => entry.isIntersecting)
          .sort(
            (a, b) => Math.abs(a.boundingClientRect.top) - Math.abs(b.boundingClientRect.top),
          )[0];
        if (!active) return;
        const next = Number((active.target as HTMLElement).dataset.objectiveIndex);
        objectiveRows.forEach((row) => row.toggleAttribute('data-current', row === active.target));
        animateObjective(next);
      },
      { rootMargin: '-34% 0px -52%', threshold: 0.05 },
    );
    objectiveRows.forEach((row) => objectiveObserver.observe(row));
  }
</script>

<style>
  .about-hero {
    position: relative;
    overflow: hidden;
    min-height: 48rem;
    padding: 10rem 0 var(--space-7);
    background: var(--paper);
  }
  .about-lead {
    position: relative;
    z-index: 1;
  }
  .about-lead h1 {
    max-width: 12ch;
  }
  .lead-detail {
    margin-top: var(--space-6);
  }
  .about-orbit i {
    position: absolute;
    display: block;
    border-radius: 50%;
  }
  .about-orbit i:first-child {
    width: min(30vw, 25rem);
    aspect-ratio: 1;
    right: -7rem;
    bottom: -5rem;
    --orbit-stroke: 6rem;
    --orbit-duration: 36s;
  }
  .about-orbit i:last-child {
    width: 8rem;
    aspect-ratio: 1;
    right: 24%;
    top: 17%;
    background: var(--coral);
  }
  .about-context {
    position: absolute;
    z-index: 2;
    right: clamp(2rem, 8vw, 8rem);
    bottom: clamp(4rem, 10vw, 8rem);
    margin: 0;
    color: white;
    font-size: var(--step--1);
    font-weight: 850;
    letter-spacing: 0.1em;
    line-height: 1.6;
    text-transform: uppercase;
  }
  .purpose {
    padding-block: var(--space-8);
    border-block: 1px solid var(--line);
    background: var(--pink);
    color: var(--navy-950);
  }
  .purpose-grid {
    display: grid;
    grid-template-columns: 0.35fr 1.3fr 0.6fr;
    gap: var(--space-6);
    align-items: start;
  }
  blockquote {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--step-3);
    letter-spacing: -0.05em;
    line-height: 1.02;
  }
  .purpose-grid > p:last-child {
    color: var(--muted-ink);
  }
  .work {
    padding-block: var(--space-8);
    background: var(--paper);
    color: var(--navy-950);
  }
  .work-grid {
    display: grid;
    grid-template-columns: minmax(20rem, 0.9fr) minmax(0, 1.1fr);
    gap: var(--space-7);
    align-items: start;
  }
  .work header {
    position: sticky;
    top: 9rem;
    align-self: start;
    min-height: 31rem;
    overflow: hidden;
    padding: var(--space-6);
    border: 1px solid var(--navy-950);
    background: var(--amber-soft);
    box-shadow: 0.75rem 0.75rem 0 var(--coral);
    color: var(--navy-950);
  }
  .work h2 {
    position: relative;
    z-index: 1;
    max-width: 9ch;
  }
  .work header .eyebrow {
    position: relative;
    z-index: 1;
    max-width: 24ch;
  }
  .work-progress {
    position: relative;
    z-index: 1;
    margin-top: var(--space-5);
    font-size: var(--step--1);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .work-progress strong {
    display: inline-block;
    min-width: 1.7rem;
    color: var(--coral);
    font-family: var(--font-display);
    font-size: var(--step-1);
  }
  .work-ghost {
    position: absolute;
    right: -0.08em;
    bottom: -0.18em;
    color: rgba(23, 33, 59, 0.07);
    font-family: var(--font-display);
    font-size: clamp(12rem, 22vw, 20rem);
    letter-spacing: -0.12em;
    line-height: 0.75;
  }
  .objective-list {
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--navy-950);
    list-style: none;
  }
  .objective-list li {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: var(--space-3);
    min-height: clamp(10rem, 22vh, 15rem);
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--line);
    align-content: center;
    transition:
      opacity var(--motion-medium),
      transform var(--motion-medium);
  }
  [data-objective-story][data-enhanced] .objective-list li:not([data-current]) {
    opacity: 0.48;
  }
  [data-objective-story][data-enhanced] .objective-list li[data-current] {
    opacity: 1;
    transform: translateX(-0.75rem);
  }
  .objective-list span {
    color: var(--coral);
    font-size: var(--step--1);
    font-weight: 850;
  }
  .objective-list p {
    max-width: 40rem;
    margin: 0;
    font-size: var(--step-1);
    line-height: 1.35;
  }
  .principles {
    padding-block: var(--space-8);
    background: var(--sky);
  }
  .timeline {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-8);
    background: var(--paper);
  }
  .timeline::after {
    position: absolute;
    top: -9rem;
    right: -8rem;
    width: 23rem;
    aspect-ratio: 1;
    border: 5rem solid var(--amber-soft);
    border-radius: 50%;
    content: '';
    pointer-events: none;
  }
  .timeline-intro {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    margin-bottom: var(--space-7);
  }
  .timeline-intro h2 {
    max-width: 10ch;
  }
  .plan-note {
    max-width: 39rem;
    padding-left: var(--space-3);
    border-left: 3px solid var(--coral);
    color: var(--muted-ink);
    font-size: var(--step--1);
  }
  .timeline-shell {
    position: relative;
  }
  .timeline-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: calc(6rem - 1px);
    width: 2px;
    background: var(--navy-950);
  }
  .timeline-list {
    position: relative;
    z-index: 1;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .timeline-list > li {
    display: grid;
    grid-template-columns: 12rem minmax(0, 1fr);
    gap: var(--space-6);
    padding-bottom: var(--space-6);
  }
  .timeline-list > li:nth-child(even) article {
    margin-left: clamp(0rem, 8vw, 7rem);
  }
  .phase-marker {
    display: grid;
    width: 4.5rem;
    aspect-ratio: 1;
    margin-left: 3.75rem;
    border: 2px solid var(--navy-950);
    border-radius: 50%;
    place-items: center;
    background: var(--cream);
    box-shadow: 0.35rem 0.35rem 0 var(--coral);
  }
  .phase-marker span {
    font-family: var(--font-display);
    font-size: var(--step-1);
  }
  .timeline-list article {
    max-width: 49rem;
    padding: var(--space-5);
    border: 1px solid var(--line);
    border-radius: 0 var(--radius-large) 0 var(--radius-medium);
    background: var(--cream);
  }
  .timeline-list > li:nth-child(2) article,
  .timeline-list > li:nth-child(5) article {
    background: var(--sky);
  }
  .timeline-list > li:nth-child(4) article {
    background: var(--amber-soft);
  }
  .phase-period {
    margin-bottom: var(--space-3);
    font-size: var(--step--1);
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .timeline-list h3 {
    max-width: 18ch;
    margin-bottom: var(--space-4);
  }
  .timeline-list article ul {
    margin: 0;
    padding-left: 1.15rem;
  }
  .timeline-list article li {
    margin-bottom: var(--space-2);
  }
  .principles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
  }
  .principles h2 {
    max-width: 11ch;
  }
  .principles ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .principles li {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--navy-950);
    font-weight: 750;
  }
  .about-next {
    padding-block: var(--space-8);
    background: var(--paper);
  }
  .next-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-7);
    align-items: end;
  }
  .next-grid h2 {
    max-width: 10ch;
    margin: 0;
  }
  .next-grid .button-link {
    margin: var(--space-3) var(--space-3) 0 0;
  }
  .text-link {
    font-weight: 750;
  }
  @media (max-width: 48rem) {
    .about-hero {
      min-height: 40rem;
    }
    .lead-detail,
    .purpose-grid,
    .work-grid,
    .timeline-intro,
    .principles-grid,
    .next-grid {
      grid-template-columns: 1fr;
    }
    .work header {
      position: static;
      min-height: 25rem;
      padding: var(--space-4);
    }
    .objective-list li {
      min-height: auto;
      padding-block: var(--space-5);
      opacity: 1 !important;
      transform: none !important;
    }
    .about-orbit i:first-child {
      right: -9rem;
      width: 20rem;
      --orbit-stroke: 5rem;
    }
    .about-context {
      right: 1rem;
      bottom: 3rem;
      max-width: 9rem;
      font-size: 0.68rem;
    }
    .timeline-line {
      left: 1.75rem;
    }
    .timeline-list > li {
      grid-template-columns: 3.5rem minmax(0, 1fr);
      gap: var(--space-3);
    }
    .timeline-list > li:nth-child(even) article {
      margin-left: 0;
    }
    .phase-marker {
      width: 3.5rem;
      margin-left: 0;
    }
    .timeline-list article {
      padding: var(--space-4);
    }
  }
</style>

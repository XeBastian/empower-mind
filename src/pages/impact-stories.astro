---
import ContentPending from '@/components/editorial/ContentPending.astro';
import PageLead from '@/components/editorial/PageLead.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Impact & stories"
  description="Empower Mind stories and impact evidence will be published after evidence, consent, and safeguarding review."
  noindex
>
  <PageLead
    eyebrow="Impact & stories"
    title="Change should be shown with evidence, context, and consent."
    summary="This space will bring together approved field stories, learning, and outcomes without turning people into promotional proof."
  />
  <ContentPending
    title="Stories and impact claims are awaiting evidence, consent, and safeguarding review."
  />
</BaseLayout>

---
import ContentPending from '@/components/editorial/ContentPending.astro';
import PageLead from '@/components/editorial/PageLead.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Get involved"
  description="Participation information for Empower Mind will be published after pathways and response expectations are approved."
  noindex
>
  <PageLead
    eyebrow="Participation"
    title="A useful invitation explains what happens next."
    summary="Partnership, volunteering, support, and participation routes will appear only where Empower Mind has confirmed the process and capacity to respond."
  />
  <ContentPending title="Participation pathways and response expectations are awaiting approval." />
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/data/site';
---

<BaseLayout
  title="Programmes"
  description="Explore Empower Mind Chapters, university-student suicide prevention, and school mental-health awareness and career guidance programmes in Malawi."
>
  <section class="programme-hero">
    <div class="container programme-lead" data-reveal="immediate">
      <p class="eyebrow">Programmes</p><h1>
        Work designed around where young people learn and connect.
      </h1><p class="lede">
        Three confirmed programme areas link campuses, prevention, schools, peer support, and
        referral pathways.
      </p>
    </div><div class="programme-signal" aria-hidden="true">
      <span>03</span><i class="orbit-motion"></i>
    </div>
  </section>

  <nav class="programme-index" aria-label="Programme index" data-programme-index>
    <div class="container">
      <a href="#chapters" data-programme-link="chapters">01 Chapters</a><a
        href="#prevention"
        data-programme-link="prevention">02 Prevention</a
      ><a href="#schools" data-programme-link="schools">03 Schools</a>
    </div>
  </nav>

  <section id="chapters" class="programme-section chapters" data-chapter-story>
    <div class="container programme-grid">
      <div class="chapter-stage">
        <div class="chapter-seed-line" aria-hidden="true"></div>
        <div class="chapter-panel" data-chapter-panel>
          <span class="chapter-ghost" data-chapter-ghost aria-hidden="true">01</span>
          <p class="programme-number">Programme 01 · Established chapter model</p><h2>
            Empower Mind Chapters
          </h2><p class="lede">
            An institutionalized model across five higher-education institutions, connected to the
            organization’s peer-support, referral, training, and mentorship approach.
          </p>
          <p class="chapter-expansion">
            <strong>More chapters coming soon.</strong> Empower Mind Initiative is continuing to establish
            chapters in universities, secondary schools, and communities across Malawi.
          </p>
          <p class="chapter-progress" aria-hidden="true">
            Chapter <strong data-chapter-counter>01</strong> of 05
          </p>
          <a
            class="button-link"
            href={`mailto:${site.contact.email}?subject=Empower Mind Chapters enquiry`}
            >Ask about chapters</a
          >
        </div>
      </div><ol class="institution-list" aria-label="Chapter institutions">
        {
          site.chapters.map((chapter, index) => (
            <li
              data-reveal
              data-chapter-index={index + 1}
              style={`--reveal-delay: ${index * 60}ms`}
            >
              <>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <strong>{chapter}</strong>
              </>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section id="prevention" class="programme-section prevention">
    <div class="container prevention-grid">
      <div class="prevention-mark" aria-hidden="true" data-reveal>
        <i class="orbit-motion"></i><span>02</span>
      </div><div data-reveal>
        <p class="programme-number">Programme 02 · University settings</p><h2>
          Suicide Prevention Among University Students
        </h2><p class="lede">
          This prevention project is delivered through the existing Empower Mind chapter network.
        </p><div class="method-line">
          <span>Prevention</span><span>Early identification</span><span>Referral</span><span
            >Peer support</span
          >
        </div><p class="status-note">
          Participation criteria, dates, and programme-specific contact routes have not yet been
          published. The confirmed organization email is available for enquiries.
        </p><a
          class="button-link"
          href={`mailto:${site.contact.email}?subject=University suicide prevention programme enquiry`}
          >Make an enquiry</a
        >
      </div>
    </div>
  </section>

  <section id="schools" class="programme-section schools">
    <div class="container schools-grid">
      <header data-reveal>
        <p class="programme-number">Programme 03 · Primary and secondary schools</p><h2>
          Mental Health Awareness Campaigns and Career Guidance in Schools
        </h2>
      </header><div class="school-copy" data-reveal>
        <p class="lede">
          A school programme bringing mental-health awareness and career guidance into primary- and
          secondary-school settings.
        </p><div class="school-settings">
          <span>Primary schools</span><span>Secondary schools</span>
        </div><p class="status-note">
          School locations, schedules, access criteria, and delivery details remain unpublished and
          are not implied here.
        </p><a
          class="button-link"
          href={`mailto:${site.contact.email}?subject=School programme enquiry`}
          >Contact Empower Mind</a
        >
      </div>
    </div>
  </section>

  <section class="programme-trust">
    <div class="container trust-grid" data-reveal>
      <div>
        <p class="eyebrow">Across the work</p><h2>Accountability travels with delivery.</h2>
      </div><div>
        <p>
          Empower Mind’s stated approach includes results-based monitoring and evaluation, quarterly
          implementation reporting to the Ministry of Health, attendance registers, activity
          reports, referral logs, and feedback tools.
        </p><p>
          <strong>Principles:</strong> ethical standards, confidentiality, safeguarding, and informed
          consent.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const story = document.querySelector<HTMLElement>('[data-chapter-story]');
  const rows = story?.querySelectorAll<HTMLElement>('[data-chapter-index]');
  const counter = story?.querySelector<HTMLElement>('[data-chapter-counter]');
  const ghost = story?.querySelector<HTMLElement>('[data-chapter-ghost]');
  const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  const programmeLinks = document.querySelectorAll<HTMLAnchorElement>('[data-programme-link]');
  const programmeSections = document.querySelectorAll<HTMLElement>(
    '#chapters, #prevention, #schools',
  );
  if (programmeLinks.length && programmeSections.length && 'IntersectionObserver' in window) {
    const setCurrentProgramme = (id: string) => {
      programmeLinks.forEach((link) => {
        const current = link.dataset.programmeLink === id;
        link.toggleAttribute('data-current', current);
        if (current) link.setAttribute('aria-current', 'location');
        else link.removeAttribute('aria-current');
      });
    };
    const programmeObserver = new IntersectionObserver(
      (entries) => {
        const active = entries
          .filter((entry) => entry.isIntersecting)
          .sort(
            (a, b) => Math.abs(a.boundingClientRect.top) - Math.abs(b.boundingClientRect.top),
          )[0];
        if (active?.target.id) setCurrentProgramme(active.target.id);
      },
      { rootMargin: '-18% 0px -62%', threshold: 0.01 },
    );
    programmeSections.forEach((section) => programmeObserver.observe(section));
    setCurrentProgramme(location.hash.slice(1) || 'chapters');
  }

  if (story && rows?.length && counter && ghost && 'IntersectionObserver' in window) {
    story.setAttribute('data-enhanced', '');
    const storyObserver = new IntersectionObserver(
      ([entry]) => story.classList.toggle('is-active', entry?.isIntersecting ?? false),
      { rootMargin: '-12% 0px -12%', threshold: 0.08 },
    );
    storyObserver.observe(story);

    let current = 1;
    const renderNumber = (value: number) => {
      const text = String(value).padStart(2, '0');
      counter.textContent = text;
      ghost.textContent = text;
    };
    const animateNumber = (next: number) => {
      if (reducedMotion || next === current) {
        current = next;
        renderNumber(next);
        return;
      }
      const start = current;
      const startedAt = performance.now();
      const tick = (now: number) => {
        const progress = Math.min(1, (now - startedAt) / 320);
        renderNumber(Math.round(start + (next - start) * progress));
        if (progress < 1) requestAnimationFrame(tick);
        else current = next;
      };
      requestAnimationFrame(tick);
    };
    const rowObserver = new IntersectionObserver(
      (entries) => {
        const active = entries
          .filter((entry) => entry.isIntersecting)
          .sort(
            (a, b) => Math.abs(a.boundingClientRect.top) - Math.abs(b.boundingClientRect.top),
          )[0];
        if (!active) return;
        const next = Number((active.target as HTMLElement).dataset.chapterIndex);
        rows.forEach((row) => row.toggleAttribute('data-current', row === active.target));
        animateNumber(next);
      },
      { rootMargin: '-34% 0px -52%', threshold: 0.05 },
    );
    rows.forEach((row) => rowObserver.observe(row));
  }
</script>

<style>
  .programme-hero {
    position: relative;
    min-height: 44rem;
    overflow: hidden;
    padding: 10rem 0 var(--space-7);
    background: var(--paper);
  }
  .programme-lead {
    position: relative;
    z-index: 1;
  }
  .programme-lead h1 {
    max-width: 13ch;
  }
  .programme-signal {
    position: absolute;
    top: 4.5rem;
    right: -2.5rem;
    display: flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: var(--step-5);
    color: rgba(23, 33, 59, 0.16);
  }
  .programme-signal i {
    position: relative;
    width: clamp(12rem, 20vw, 18rem);
    aspect-ratio: 1;
    margin-left: -2.5rem;
    border-radius: 50%;
    --orbit-color: var(--coral);
    --orbit-accent: var(--amber-soft);
    --orbit-stroke: clamp(2.5rem, 4vw, 4rem);
    --orbit-duration: 22s;
  }
  .programme-index {
    position: sticky;
    z-index: 15;
    top: 5rem;
    border-block: 1px solid var(--line);
    background: rgba(248, 244, 236, 0.92);
    backdrop-filter: blur(14px);
  }
  .programme-index .container {
    display: flex;
    gap: var(--space-5);
    overflow-x: auto;
    padding-block: 0.8rem;
  }
  .programme-index a {
    position: relative;
    flex: 0 0 auto;
    padding: 0.35rem 0 0.45rem 1rem;
    color: var(--muted-ink);
    font-size: var(--step--1);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      color var(--motion-fast),
      transform var(--motion-fast);
  }
  .programme-index a::before {
    position: absolute;
    top: 50%;
    left: 0;
    width: 0.42rem;
    aspect-ratio: 1;
    border: 1px solid currentColor;
    border-radius: 50%;
    content: '';
    transform: translateY(-65%) scale(0.65);
    transition:
      background var(--motion-fast),
      transform var(--motion-fast);
  }
  .programme-index a::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 1rem;
    height: 2px;
    background: var(--coral);
    content: '';
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--motion-medium);
  }
  .programme-index a[data-current] {
    color: var(--navy-950);
    transform: translateY(-1px);
  }
  .programme-index a[data-current]::before {
    border-color: var(--coral);
    background: var(--coral);
    transform: translateY(-65%) scale(1);
  }
  .programme-index a[data-current]::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  .programme-section {
    scroll-margin-top: 9rem;
    padding-block: var(--space-8);
  }
  .programme-grid {
    display: grid;
    grid-template-columns: minmax(20rem, 0.9fr) minmax(0, 1.1fr);
    gap: var(--space-7);
    align-items: start;
  }
  .programme-number {
    font-size: var(--step--1);
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .programme-section h2 {
    max-width: 12ch;
  }
  .chapters {
    position: relative;
    background: var(--navy-950);
    color: var(--cream);
  }
  .chapter-stage {
    position: sticky;
    top: 9rem;
    min-height: 34rem;
  }
  .chapter-seed-line {
    position: absolute;
    top: 4rem;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--coral);
    transform-origin: left;
    transition:
      opacity var(--motion-medium),
      transform var(--motion-medium);
  }
  .chapter-panel {
    position: relative;
    min-height: 32rem;
    overflow: hidden;
    padding: var(--space-6);
    border: 1px solid rgba(248, 244, 236, 0.28);
    background: var(--cream);
    color: var(--navy-950);
  }
  [data-chapter-story][data-enhanced] .chapter-panel {
    clip-path: inset(0 100% 0 0);
    opacity: 0;
    transform: translateX(2rem);
    transition:
      clip-path var(--motion-slow),
      opacity var(--motion-medium),
      transform var(--motion-slow);
  }
  [data-chapter-story][data-enhanced].is-active .chapter-panel {
    clip-path: inset(0);
    opacity: 1;
    transform: none;
  }
  [data-chapter-story][data-enhanced].is-active .chapter-seed-line {
    opacity: 0;
    transform: scaleX(0.12);
  }
  .chapter-panel > *:not(.chapter-ghost) {
    position: relative;
    z-index: 1;
  }
  .chapter-panel h2 {
    max-width: 9ch;
  }
  .chapter-panel .lede {
    max-width: 30rem;
    font-size: 1.08rem;
  }
  .chapter-ghost {
    position: absolute;
    right: -0.08em;
    bottom: -0.18em;
    color: rgba(23, 33, 59, 0.07);
    font-family: var(--font-display);
    font-size: clamp(11rem, 22vw, 20rem);
    letter-spacing: -0.12em;
    line-height: 0.75;
    transition: opacity var(--motion-fast);
  }
  .chapter-progress {
    margin: var(--space-5) 0 var(--space-3);
    font-size: var(--step--1);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .chapter-expansion {
    max-width: 38rem;
    font-size: var(--step--1);
  }
  .chapter-progress strong {
    display: inline-block;
    min-width: 1.6rem;
    color: var(--coral);
    font-family: var(--font-display);
    font-size: var(--step-1);
  }
  .institution-list {
    margin: 0;
    padding: 0;
    border-top: 1px solid rgba(248, 244, 236, 0.35);
    list-style: none;
  }
  .institution-list li {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--space-3);
    min-height: clamp(15rem, 38vh, 24rem);
    padding: var(--space-6) 0;
    border-bottom: 1px solid rgba(248, 244, 236, 0.35);
    align-content: center;
    transition:
      opacity var(--motion-medium),
      transform var(--motion-medium);
  }
  .institution-list li:not([data-current]) {
    opacity: 0.55;
  }
  .institution-list li[data-current] {
    opacity: 1;
    transform: translateX(-0.75rem);
  }
  .institution-list span {
    font-size: var(--step--1);
  }
  .institution-list strong {
    font-size: var(--step-1);
    line-height: 1.3;
  }
  .prevention {
    background: var(--cream);
  }
  .prevention-grid {
    display: grid;
    grid-template-columns: 0.65fr 1.2fr;
    gap: var(--space-7);
    align-items: center;
  }
  .prevention-mark {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 28rem;
  }
  .prevention-mark i {
    position: absolute;
    width: min(30vw, 22rem);
    aspect-ratio: 1;
    border-radius: 50%;
    --orbit-color: var(--sky);
    --orbit-accent: var(--pink);
    --orbit-stroke: clamp(3rem, 6vw, 5rem);
    --orbit-duration: 28s;
  }
  .prevention-mark span {
    z-index: 1;
    font-family: var(--font-display);
    font-size: var(--step-5);
  }
  .method-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-block: var(--space-5);
  }
  .method-line span,
  .school-settings span {
    padding: 0.45rem 0.75rem;
    border: 1px solid currentColor;
    border-radius: var(--radius-round);
    font-size: var(--step--1);
    font-weight: 750;
  }
  .status-note {
    max-width: 42rem;
    padding-left: var(--space-3);
    border-left: 3px solid var(--coral);
    color: var(--muted-ink);
    font-size: var(--step--1);
  }
  .schools {
    background: var(--sky);
  }
  .schools-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: var(--space-7);
    align-items: end;
  }
  .schools h2 {
    max-width: 16ch;
  }
  .school-settings {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-block: var(--space-5);
  }
  .programme-trust {
    padding-block: var(--space-8);
    background: var(--paper);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
  }
  .trust-grid h2 {
    max-width: 11ch;
  }
  @media (max-width: 48rem) {
    .programme-hero {
      min-height: 40rem;
    }
    .programme-grid,
    .prevention-grid,
    .schools-grid,
    .trust-grid {
      grid-template-columns: 1fr;
    }
    .programme-signal {
      top: 4rem;
      right: -5rem;
      opacity: 0.28;
    }
    .programme-signal i {
      width: 13rem;
      --orbit-stroke: 3rem;
    }
    .chapter-stage {
      position: relative;
      top: auto;
      min-height: auto;
      margin-bottom: var(--space-6);
    }
    .chapter-seed-line {
      display: none;
    }
    [data-chapter-story][data-enhanced] .chapter-panel,
    [data-chapter-story][data-enhanced].is-active .chapter-panel {
      clip-path: none;
      opacity: 1;
      transform: none;
    }
    .chapter-panel {
      min-height: 27rem;
      padding: var(--space-4);
    }
    .institution-list li {
      min-height: auto;
      padding-block: var(--space-5);
      opacity: 1 !important;
      transform: none !important;
    }
    .prevention-mark {
      min-height: 14rem;
    }
    .prevention-mark i {
      width: 12rem;
      --orbit-stroke: 3rem;
    }
  }
  @supports not (backdrop-filter: blur(1rem)) {
    .programme-index {
      background: var(--cream);
    }
  }
</style>

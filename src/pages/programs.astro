---
import ChapterNetwork from '@/components/programmes/ChapterNetwork.astro';
import ProgrammePrevention from '@/components/programmes/ProgrammePrevention.astro';
import ProgrammeSchools from '@/components/programmes/ProgrammeSchools.astro';
import ProgrammesHero from '@/components/programmes/ProgrammesHero.astro';
import ProgrammesIndex from '@/components/programmes/ProgrammesIndex.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/programmes/foundation.css';
---

<BaseLayout
  title="Programmes"
  description="Explore Empower Mind's university-student suicide prevention and school mental-health awareness and career guidance programmes, alongside its separate chapter network in Malawi."
>
  <ProgrammesHero />
  <div class="programmes-directory">
    <ProgrammesIndex />
    <ProgrammePrevention />
    <ProgrammeSchools />
  </div>
  <ChapterNetwork />
</BaseLayout>

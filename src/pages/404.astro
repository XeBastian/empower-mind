---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" noindex>
  <section class="not-found">
    <div class="container not-found-grid">
      <div data-reveal="immediate">
        <p class="eyebrow">Error 404</p>
        <h1>That page isn’t here.</h1>
        <p class="lede">
          The link may be out of date, or the address may have been entered incorrectly.
        </p>
        <div class="actions">
          <a class="button-link" href="/">Return home</a><a href="/programs">Explore programmes</a>
        </div>
      </div>
      <div class="lost-mark" aria-hidden="true" data-reveal="immediate">
        <span>4</span><i></i><span>4</span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 100svh;
    display: grid;
    align-items: center;
    padding-block: 7rem var(--space-7);
    background: var(--paper);
  }
  .not-found-grid {
    display: grid;
    grid-template-columns: 1fr 0.8fr;
    gap: var(--space-6);
    align-items: center;
  }
  h1 {
    max-width: 9ch;
    margin-bottom: var(--space-4);
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    margin-top: var(--space-5);
  }
  .lost-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: clamp(6rem, 17vw, 15rem);
    letter-spacing: -0.12em;
    line-height: 0.7;
  }
  .lost-mark i {
    width: clamp(5rem, 12vw, 11rem);
    aspect-ratio: 1;
    margin-inline: -0.08em;
    border: clamp(1rem, 3vw, 2.5rem) solid var(--coral);
    border-right-color: var(--amber-soft);
    border-radius: 50%;
    transform: rotate(-25deg);
    animation: orbit 12s linear infinite;
  }
  @keyframes orbit {
    to {
      transform: rotate(335deg);
    }
  }
  @media (max-width: 48rem) {
    .not-found-grid {
      grid-template-columns: 1fr;
    }
    .lost-mark {
      grid-row: 1;
      justify-content: flex-start;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .lost-mark i {
      animation: none;
    }
  }
</style>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/data/site';

const donationProgrammes = site.programs.map((programme) => ({
  ...programme,
  emailHref: `mailto:${site.contact.email}?subject=${encodeURIComponent(
    `Donation enquiry — ${programme.title}`,
  )}`,
}));
---

<BaseLayout
  title="Donate"
  description="Explore Empower Mind programme areas available for donation and funding enquiries, and contact the organization directly about supporting its work in Malawi."
>
  <section class="donate-hero">
    <div class="container donate-hero-grid">
      <div class="donate-lead" data-reveal="immediate">
        <p class="eyebrow">Donate to Empower Mind</p>
        <h1>Back the work where young people learn and connect.</h1>
        <p class="lede">
          Start a direct conversation about supporting one of Empower Mind’s three confirmed
          programme areas in Malawi.
        </p>
      </div>
      <div class="donate-mark" aria-hidden="true" data-reveal="immediate">
        <i class="orbit-motion" data-parallax=".04"></i><span>03</span>
      </div>
    </div>
  </section>

  <section class="programme-support" aria-labelledby="programme-support-title">
    <div class="container support-grid">
      <header class="support-intro" data-reveal>
        <p class="eyebrow">Choose an area</p>
        <h2 id="programme-support-title">Three ways to begin the conversation.</h2>
        <p>
          Selecting a programme opens an email to Empower Mind. It expresses your area of interest;
          it does not make or restrict a payment.
        </p>
      </header>

      <ol class="support-list">
        {
          donationProgrammes.map((programme, index) => (
            <li data-reveal style={`--reveal-delay: ${index * 70}ms`}>
              <span class="support-number">{programme.number}</span>
              <div>
                <h3>{programme.title}</h3>
                <p>{programme.summary}</p>
              </div>
              <a href={programme.emailHref} aria-label={`Ask about donating to ${programme.title}`}>
                Support this area <span aria-hidden="true">↗</span>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="donation-process" aria-labelledby="donation-process-title">
    <div class="container process-grid">
      <div data-reveal>
        <p class="eyebrow">A transparent first step</p>
        <h2 id="donation-process-title">Talk before you transfer.</h2>
      </div>
      <div class="process-copy" data-reveal>
        <p>
          Empower Mind has not yet supplied approved online payment, bank, or mobile-money details
          for publication. This website therefore does not collect donations or financial
          information.
        </p>
        <p>
          Contact the organization directly to ask which support arrangements are currently
          available and what information can be provided before you donate.
        </p>
        <a
          class="button-link"
          href={`mailto:${site.contact.email}?subject=General donation enquiry`}
        >
          Email Empower Mind
        </a>
      </div>
    </div>
  </section>

  <aside class="donation-note">
    <div class="container note-grid">
      <strong>Important</strong>
      <p>
        Programme budgets, funding targets, tax treatment, payment methods, and donation receipts
        are crucial for you. Always Confirm these details with Empower Mind before sending funds.
      </p>
    </div>
  </aside>
</BaseLayout>

<style>
  .donate-hero {
    position: relative;
    overflow: hidden;
    min-height: 46rem;
    display: grid;
    align-items: center;
    padding: 9rem 0 var(--space-7);
    background: var(--paper);
  }
  .donate-hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-6);
    align-items: center;
  }
  .donate-lead h1 {
    max-width: 11ch;
  }
  .donate-mark {
    position: relative;
    display: grid;
    min-height: 25rem;
    place-items: center;
  }
  .donate-mark i {
    position: absolute;
    width: min(30vw, 23rem);
    aspect-ratio: 1;
    border-radius: 50%;
    transform: rotate(-18deg);
    --orbit-color: var(--navy-950);
    --orbit-accent: var(--coral);
    --orbit-stroke: clamp(3.5rem, 7vw, 5.5rem);
    --orbit-duration: 30s;
  }
  .donate-mark span {
    z-index: 1;
    color: var(--paper);
    font-family: var(--font-display);
    font-size: var(--step-5);
    line-height: 1;
  }
  .programme-support {
    padding-block: var(--space-8);
    background: var(--cream);
  }
  .support-grid {
    display: grid;
    grid-template-columns: minmax(15rem, 0.7fr) minmax(0, 1.3fr);
    gap: var(--space-7);
    align-items: start;
  }
  .support-intro {
    position: sticky;
    top: 7rem;
  }
  .support-intro h2 {
    max-width: 10ch;
    font-size: var(--step-3);
  }
  .support-intro p:last-child {
    max-width: 34rem;
  }
  .support-list {
    margin: 0;
    padding: 0;
    border-top: var(--rule);
    list-style: none;
  }
  .support-list li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: var(--space-4);
    align-items: start;
    padding: var(--space-5) 0;
    border-bottom: var(--rule);
  }
  .support-number {
    color: var(--coral);
    font-family: var(--font-display);
    font-size: var(--step-2);
    line-height: 1;
  }
  .support-list h3 {
    max-width: 22ch;
    margin-bottom: var(--space-3);
    font-size: var(--step-2);
  }
  .support-list p {
    max-width: 40rem;
    margin: 0;
    color: var(--muted-ink);
  }
  .support-list a {
    align-self: end;
    white-space: nowrap;
    font-size: var(--step--1);
    font-weight: 800;
  }
  .donation-process {
    padding-block: var(--space-8);
    background: var(--navy-950);
    color: var(--cream);
  }
  .process-grid {
    display: grid;
    grid-template-columns: 1fr 0.85fr;
    gap: var(--space-7);
  }
  .process-grid h2 {
    max-width: 10ch;
  }
  .process-copy {
    max-width: 38rem;
    padding-top: var(--space-5);
    border-top: 1px solid rgba(248, 244, 236, 0.35);
  }
  .process-copy .button-link {
    margin-top: var(--space-3);
  }
  .donation-note {
    padding-block: var(--space-5);
    background: var(--amber-soft);
  }
  .note-grid {
    display: grid;
    grid-template-columns: 0.3fr 1fr;
    gap: var(--space-5);
  }
  .note-grid p {
    max-width: 55rem;
    margin: 0;
  }
  @media (max-width: 48rem) {
    .donate-hero {
      min-height: 42rem;
    }
    .donate-hero-grid,
    .support-grid,
    .process-grid,
    .note-grid {
      grid-template-columns: 1fr;
    }
    .donate-mark {
      min-height: 12rem;
      opacity: 0.5;
    }
    .donate-mark i {
      width: 11rem;
      --orbit-stroke: 2.6rem;
    }
    .support-intro {
      position: static;
    }
    .support-list li {
      grid-template-columns: auto minmax(0, 1fr);
    }
    .support-list a {
      grid-column: 2;
      justify-self: start;
      margin-top: var(--space-2);
      white-space: normal;
    }
  }
</style>

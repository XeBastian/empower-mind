---
import '@/styles/errors/not-found.css';
---

<section class="not-found" aria-labelledby="not-found-title">
  <div class="not-found__number" aria-hidden="true">
    <span>4</span><span>0</span><span>4</span>
  </div>

  <div class="container not-found__content" data-reveal="immediate">
    <p class="eyebrow">Page not found</p>
    <h1 id="not-found-title">Wrong turn.<br />Strong recovery.</h1>
    <p>The address may be incorrect or the page may have moved.</p>
    <div class="not-found__actions">
      <a class="not-found__primary" href="/">Return home <span aria-hidden="true">→</span></a>
      <a href="/programs">Explore programmes</a>
    </div>
  </div>
</section>

---
interface Props {
  eyebrow: string;
  title: string;
  summary: string;
}

const { eyebrow, title, summary } = Astro.props;
---

<section class="page-lead container" data-reveal>
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <p class="lede measure">{summary}</p>
</section>

<style>
  .page-lead {
    padding-block: clamp(5rem, 12vw, 10rem);
  }

  .page-lead h1 {
    max-width: 16ch;
    margin-bottom: var(--space-5);
  }
</style>

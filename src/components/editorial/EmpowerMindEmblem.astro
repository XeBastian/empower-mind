---
import '@/styles/editorial/empower-mind-emblem.css';
---

<div
  class="empower-emblem"
  role="img"
  aria-label="Empower Mind Initiative connected with universities, schools, and young people"
  data-reveal="immediate"
>
  <div class="empower-emblem__orbit empower-emblem__orbit--a" aria-hidden="true"><i></i></div>
  <div class="empower-emblem__orbit empower-emblem__orbit--b" aria-hidden="true"><i></i></div>
  <div class="empower-emblem__centre">
    <img src="/brand/logos/logo.png" alt="" width="775" height="775" />
  </div>
  <span class="empower-emblem__label empower-emblem__label--universities">Universities</span>
  <span class="empower-emblem__label empower-emblem__label--schools">Schools</span>
  <span class="empower-emblem__label empower-emblem__label--youth">Young people</span>
</div>

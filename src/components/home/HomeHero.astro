---
import { site } from '@/data/site';
import EmpowerMindEmblem from '@/components/editorial/EmpowerMindEmblem.astro';
import '@/styles/home/hero.css';
---

<section class="home-hero">
  <div class="container home-hero__grid">
    <div class="home-hero__copy" data-reveal="immediate">
      <h1>Young minds.<br /><span>Stronger circles</span> of support.</h1>
      <p class="lede">
        Empower Mind Initiative connects young people, schools, universities, communities, and
        public systems around mental health and psychosocial well-being.
      </p>
      <div class="home-hero__actions">
        <a class="button-link" href="/programs">Explore programmes</a>
        <a class="text-link" href="/about">Meet Empower Mind <span aria-hidden="true">→</span></a>
      </div>
    </div>

    <EmpowerMindEmblem />
  </div>

  <div class="container home-proof" data-reveal>
    <p><strong>5,000+</strong><span>young people reached since November 2022</span></p>
    <p><strong>{site.chapters.length}</strong><span>higher-education chapters</span></p>
    <p><strong>2</strong><span>districts reached: Zomba & Machinga</span></p>
  </div>
</section>

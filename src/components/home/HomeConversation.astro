---
import '@/styles/home/conversation.css';
---

<section class="home-conversation">
  <div class="container home-conversation__grid" data-reveal>
    <p class="eyebrow">Let’s talk</p>
    <h2>Bring a question.<br />Start a connection.</h2>
    <div>
      <p>
        For programme enquiries, research, advocacy, or institutional collaboration, talk directly
        with Empower Mind.
      </p>
      <div class="home-conversation__actions">
        <a class="button-link" href="/contact"
          >Contact the initiative <span aria-hidden="true">↗</span></a
        >
        <a class="text-link" href="/donate">Support the work <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </div>
</section>

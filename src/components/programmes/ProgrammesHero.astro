---
import '@/styles/programmes/hero.css';
---

<section class="programmes-hero">
  <div class="container programmes-hero__composition">
    <div class="programmes-hero__lead">
      <p class="eyebrow" data-reveal="immediate">Programmes</p>
      <h1 data-reveal="immediate">Where young people learn, connect, and lead.</h1>
      <p class="lede">
        Programme work shaped around universities, schools, and young people’s everyday lives.
      </p>
    </div>
    <div class="programmes-hero__routes" aria-label="Programme settings">
      <a class="programme-route route-university" href="#prevention" data-reveal="immediate">
        <span>University settings</span>
        <strong>Suicide prevention</strong>
        <i aria-hidden="true">↘</i>
      </a>
      <a class="programme-route route-schools" href="#schools" data-reveal="immediate">
        <span>Primary & secondary schools</span>
        <strong>Mental-health awareness<br />Career guidance</strong>
        <i aria-hidden="true">↘</i>
      </a>
    </div>
  </div>
</section>

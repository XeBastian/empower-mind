---
import '@/styles/programmes/donation.css';
---

<section class="programmes-donation" aria-labelledby="programmes-donation-title">
  <div class="container programmes-donation__grid" data-reveal>
    <p class="eyebrow">Support the work</p>
    <h2 id="programmes-donation-title">Help programme conversations move forward.</h2>
    <div>
      <p>
        Ask Empower Mind directly how support can connect with its university and school programme
        work.
      </p>
      <a class="programmes-donation__link" href="/donate">
        <span>Explore ways to support</span>
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</section>

---
const pathname = Astro.url.pathname;
const navigation = [
  { href: '/programs', label: 'Programmes' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header" data-site-header>
  <div class="header-shell">
    <a class="brand" href="/" aria-label="Empower Mind Initiative home">
      <img src="/brand/logos/logo.png" alt="" width="775" height="775" />
    </a>
    <button
      class="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-navigation"
    >
      <span class="menu-icon" aria-hidden="true"></span><span class="menu-label">Menu</span>
    </button>
    <nav id="primary-navigation" class="primary-navigation" aria-label="Primary navigation">
      <div class="nav-tabs">
        {
          navigation.map((item) => (
            <a href={item.href} aria-current={pathname === item.href ? 'page' : undefined}>
              {item.label}
            </a>
          ))
        }
      </div>
      <a class="nav-contact" href="/contact">Let’s Talk <span aria-hidden="true">↗</span></a>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-site-header]');
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const nav = document.querySelector<HTMLElement>('#primary-navigation');
  const closeMenu = (returnFocus = false) => {
    toggle?.setAttribute('aria-expanded', 'false');
    nav?.removeAttribute('data-open');
    document.body.removeAttribute('data-menu-open');
    if (returnFocus) toggle?.focus();
  };
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') !== 'true';
    toggle.setAttribute('aria-expanded', String(open));
    nav?.toggleAttribute('data-open', open);
    document.body.toggleAttribute('data-menu-open', open);
  });
  nav?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => closeMenu()));
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu(true);
  });
  const updateHeader = () => header?.toggleAttribute('data-scrolled', scrollY > 24);
  addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();
</script>

<style>
  .site-header {
    position: fixed;
    z-index: 40;
    inset: 0 0 auto;
    border-bottom: 1px solid var(--line);
    background: rgba(244, 247, 251, 0.96);
    backdrop-filter: blur(16px);
    transition: box-shadow var(--motion-fast);
  }
  .site-header[data-scrolled] {
    box-shadow: 0 0.5rem 1.8rem rgba(23, 33, 59, 0.1);
  }
  .header-shell {
    width: min(100% - (2 * var(--page-gutter)), var(--container));
    min-height: 4.75rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-4);
    align-items: center;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }
  .brand img {
    width: 3.75rem;
    height: 3.75rem;
    object-fit: contain;
  }
  .primary-navigation {
    display: contents;
  }
  .nav-tabs {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2.25rem);
  }
  .primary-navigation a {
    font-size: 0.8rem;
    font-weight: 750;
    text-decoration: none;
  }
  .nav-tabs a::after {
    display: block;
    height: 1px;
    background: currentColor;
    content: '';
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--motion-fast);
  }
  .nav-tabs a:hover::after,
  .nav-tabs a[aria-current='page']::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  .nav-contact {
    justify-self: end;
    padding: 0.65rem 1rem;
    border-radius: var(--radius-round);
    background: var(--navy-950);
    color: white;
  }
  .menu-toggle {
    display: none;
    min-width: 3rem;
    min-height: 3rem;
    border: 0;
    background: var(--navy-950);
    color: white;
    align-items: center;
    justify-content: center;
  }
  .menu-icon {
    width: 1rem;
    height: 0.65rem;
    border-block: 1px solid currentColor;
  }
  .menu-label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
  }
  @media (max-width: 48rem) {
    .site-header {
      backdrop-filter: none;
    }
    .header-shell {
      grid-template-columns: auto auto;
      justify-content: space-between;
      min-height: 4.25rem;
    }
    .brand img {
      width: 3.25rem;
      height: 3.25rem;
    }
    .menu-toggle {
      display: inline-flex;
    }
    .primary-navigation {
      position: fixed;
      inset: 0;
      z-index: -1;
      display: flex;
      padding: 7rem var(--page-gutter) 3rem;
      background: var(--cream);
      opacity: 0;
      visibility: hidden;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      transform: translateY(-1rem);
      transition:
        opacity var(--motion-medium),
        transform var(--motion-medium),
        visibility var(--motion-medium);
    }
    .primary-navigation[data-open] {
      opacity: 1;
      visibility: visible;
      transform: none;
    }
    .nav-tabs {
      display: contents;
    }
    .primary-navigation a {
      font-family: var(--font-display);
      font-size: clamp(2rem, 10vw, 3rem);
      letter-spacing: -0.05em;
      line-height: 1;
    }
    .nav-contact {
      justify-self: auto;
      margin-top: var(--space-4);
      font-family: var(--font-body) !important;
      font-size: 1rem !important;
    }
    body[data-menu-open] {
      overflow: hidden;
    }
  }
  @supports not (backdrop-filter: blur(1rem)) {
    .site-header {
      background: var(--cream);
    }
  }
</style>

---
import { site } from '@/data/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-orbit" aria-hidden="true"></div>
  <div class="container footer-grid">
    <div class="footer-lead">
      <p class="eyebrow">Zomba District · Southern Region, Malawi</p><p class="footer-name">
        A stronger response starts with connection.
      </p><p>Empower Mind is building from a district pilot towards national reach.</p>
    </div>
    <div>
      <p class="footer-label">Explore</p><a href="/about">About</a><a href="/what-we-do"
        >What we do</a
      ><a href="/programs">Programmes</a><a href="/research-advocacy">Research & advocacy</a>
    </div>
    <div>
      <p class="footer-label">Contact</p><a href={`mailto:${site.contact.email}`}
        >{site.contact.email}</a
      >{site.contact.phones.map((phone) => <a href={`tel:${phone.replace(/\s/g, '')}`}>{phone}</a>)}
    </div>
  </div>
  <div class="container footer-base">
    <span>© {year} Empower Mind</span><span
      >This website is informational and is not an emergency service.</span
    >
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    padding: var(--space-8) 0 var(--space-4);
    background: var(--navy-950);
    color: var(--cream);
  }
  .footer-orbit {
    position: absolute;
    top: -8rem;
    right: -6rem;
    width: 24rem;
    aspect-ratio: 1;
    border: 5rem solid var(--coral);
    border-radius: 50%;
    opacity: 0.9;
  }
  .footer-grid {
    position: relative;
    display: grid;
    grid-template-columns: 2fr 0.8fr 1fr;
    gap: var(--space-6);
    padding-bottom: var(--space-7);
  }
  .footer-lead {
    max-width: 45rem;
  }
  .footer-name {
    max-width: 15ch;
    margin-bottom: var(--space-4);
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 0.96;
  }
  .footer-label {
    color: var(--amber);
    font-size: var(--step--1);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .footer-grid a {
    display: block;
    width: fit-content;
    margin-bottom: 0.75rem;
    overflow-wrap: anywhere;
  }
  .footer-base {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255, 248, 233, 0.28);
    color: rgba(255, 248, 233, 0.72);
    font-size: var(--step--1);
  }
  @media (max-width: 48rem) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-base {
      flex-direction: column;
    }
    .footer-orbit {
      width: 15rem;
    }
  }
</style>

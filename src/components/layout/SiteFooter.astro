---
import { site } from '@/data/site';
import '@/styles/layout/footer.css';

const year = new Date().getFullYear();
const footerNavigation = [
  { href: '/', label: 'Home' },
  { href: '/programs', label: 'Programmes' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/donate', label: 'Donate' },
] as const;
---

<footer class="site-footer">
  <div class="container footer-brand-row">
    <a class="footer-brand" href="/" aria-label="Empower Mind Initiative home">
      <img src="/brand/logos/logo.png" alt="" width="775" height="775" />
      <span>Empower Mind<br />Initiative</span>
    </a>
    <a class="footer-donate" href="/donate">
      <span>Support the work</span>
      <span aria-hidden="true">↗</span>
    </a>
  </div>

  <div class="container footer-grid">
    <div class="footer-introduction">
      <p class="footer-statement">Young minds.<br />Stronger circles.</p>
      <p>{site.shortDescription}</p>
    </div>

    <nav class="footer-sitemap" aria-label="Footer navigation">
      <p class="footer-label">Sitemap</p>
      <ol>
        {
          footerNavigation.map((item, index) => (
            <li>
              <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ol>
    </nav>

    <div class="footer-contacts">
      <p class="footer-label">Contacts</p>
      <a class="footer-email" href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
      <div class="footer-phones">
        {
          site.contact.phones.map((phone) => (
            <a href={`tel:${phone.replace(/\s/g, '')}`}>{phone}</a>
          ))
        }
      </div>
      <p class="footer-location">Zomba District<br />Southern Region, Malawi</p>
    </div>
  </div>

  <div class="container footer-base">
    <span>© {year} Empower Mind Initiative</span>
    <span>This website is informational and is not an emergency service.</span>
  </div>
</footer>

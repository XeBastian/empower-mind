---
import '@/styles/about/founded.css';
---

<section class="about-founded" aria-labelledby="founded-title">
  <div class="container about-founded__grid">
    <div class="founding-date" aria-hidden="true" data-reveal="wipe">
      <span class="founding-date__year">2022</span>
      <span class="founding-date__orbit"></span>
    </div>

    <div class="founding-copy" data-reveal>
      <p class="eyebrow">Founded in November 2022</p>
      <h2 id="founded-title">A young organization with a clear direction.</h2>
      <p class="lede">
        Empower Mind began to strengthen mental health, psychosocial well-being, and social
        resilience among adolescents, young people, women, and other vulnerable populations.
      </p>
      <a class="text-link" href="/programs"
        >Explore the programmes <span aria-hidden="true">→</span></a
      >
    </div>
  </div>
</section>
